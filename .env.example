# Copy to .env and fill in. .env is gitignored — never commit real values.

# ── Frontend / runner: PUBLIC values (safe to expose; protected by RLS) ──
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# ── Admin / migrations only: SECRET. Used by the supabase CLI to apply the
#    schema and by the maintainer to author tasks. NOT used by the frontend.
#    Treat as top-secret; rotate if leaked. ─────────────────────────────────
SUPABASE_ACCESS_TOKEN=sbp_xxx            # account-level personal access token (very privileged)
SUPABASE_PROJECT_REF=YOUR-PROJECT-ref
# Alternatively, a direct connection string for migrations:
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR-ref.supabase.co:5432/postgres
